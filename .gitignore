# LaTeX build output, except the compiled PDFs themselves, which are committed
# on purpose so the book is readable without a LaTeX toolchain (see CLAUDE.md's
# "Compiling chapters" and "The subject index" sections). Regenerate these with
# pdflatex/makeindex rather than hand-editing them.
*.aux
*.toc
*.idx
*.ind
*.ilg
*.log
*.dvi
*.out

# Raw datasets downloaded by capstone-chapter notebooks (large binaries; the
# notebook re-downloads them automatically from their public source on demand).
ch16_data/

# SyncTeX editor-sync byproducts (regenerated per-machine/editor; not build output anyone else needs).
*.synctex.gz
